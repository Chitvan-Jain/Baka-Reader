{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://api.mangadex.org/:path*"
    },
    {
      "source": "/auth/:path*",
      "destination": "https://auth.mangadex.org/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://uploads.mangadex.org/:path*"
    }
  ]
}
